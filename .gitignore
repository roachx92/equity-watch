# Local-only working artifacts (plans, specs, scratch notes). Not tracked.
docs/tasks/

# Claude Code worktrees
.claude/worktrees/

# Local secrets — Discord webhook URLs, etc. Never commit real credentials;
# .secrets/discord-webhooks.example.json is the checked-in template.
.secrets/*.json
!.secrets/*.example.json

# MkDocs build tooling & output. Canonical location is web/; the bare site/
# and site_src/ rules also catch stray builds run from the repo root.
.venv/
web/site/
web/site_src/
site/
site_src/

# CI scratch — the run digest the whats-new workflow writes for the PR body
/whats-new-digest.md

# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.pyc
